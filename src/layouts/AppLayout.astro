---
import { verifySession } from "@/lib/auth";

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// Read session from cookie
const cookie = Astro.request.headers.get("cookie") || "";
const match = cookie.match(/session=([^;]+)/);
const session = match ? await verifySession(match[1]) : null;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        color-scheme: dark;
        --app-bg: #060b16;
        --app-panel: rgba(15, 23, 42, 0.88);
        --app-panel-soft: rgba(15, 23, 42, 0.68);
        --app-border: rgba(148, 163, 184, 0.16);
        --app-text: #f8fafc;
        --app-text-muted: #94a3b8;
        --app-primary: #6366f1;
        --app-primary-2: #8b5cf6;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }

      body {
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(99, 102, 241, 0.18), transparent 28%),
          radial-gradient(circle at top right, rgba(34, 211, 238, 0.14), transparent 24%),
          linear-gradient(180deg, #030712 0%, var(--app-bg) 100%);
        color: var(--app-text);
      }

      a { color: inherit; text-decoration: none; }
      button, input, textarea, select { font: inherit; }

      .app-shell { min-height: 100vh; }

      .app-topbar {
        position: sticky;
        top: 0;
        z-index: 40;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--app-border);
        background: rgba(3, 7, 18, 0.82);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
      }

      .app-brand {
        display: flex;
        align-items: center;
        gap: 0.85rem;
      }

      .app-brand-mark {
        display: grid;
        place-items: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--app-primary), var(--app-primary-2));
        font-weight: 800;
        color: #fff;
      }

      .app-brand-copy { min-width: 0; }
      .app-brand-title {
        font-size: 0.98rem;
        font-weight: 700;
        color: #fff;
      }

      .app-topbar-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .nav-link {
        font-size: 0.88rem;
        font-weight: 500;
        color: var(--app-text-muted);
        padding: 0.35rem 0.6rem;
        border-radius: 0.4rem;
        transition: color 0.2s, background 0.2s;
      }
      .nav-link:hover {
        color: var(--app-text);
        background: rgba(255,255,255,0.04);
      }

      .hamburger {
        display: none;
        background: none;
        border: none;
        color: var(--app-text-muted);
        font-size: 1.4rem;
        cursor: pointer;
        padding: 0.25rem;
        line-height: 1;
      }

      .nav-drawer {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      @media (max-width: 720px) {
        .app-topbar { padding: 0.9rem 1rem; }
        .profile-grid { grid-template-columns: 1fr !important; }
        .profile-grid > * { order: 0 !important; }
        .hamburger { display: block; }
        .nav-drawer {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          flex-direction: column;
          background: rgba(3, 7, 18, 0.95);
          backdrop-filter: blur(18px);
          border-bottom: 1px solid var(--app-border);
          padding: 0.75rem 1.5rem;
          gap: 0.5rem;
          align-items: stretch;
        }
        .nav-drawer.open { display: flex; }
        .nav-drawer form { display: block !important; }
        .nav-drawer .nav-link {
          display: block;
          padding: 0.6rem 0.75rem;
          border-radius: 0.5rem;
        }
      }

      .app-page {
        min-height: calc(100vh - 74px);
      }

      .app-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        min-height: 2.75rem;
        padding: 0.7rem 1rem;
        border-radius: 0.85rem;
        border: 1px solid var(--app-border);
        background: rgba(255, 255, 255, 0.03);
        color: #fff;
        cursor: pointer;
      }

      .app-btn-primary {
        background: linear-gradient(135deg, var(--app-primary), var(--app-primary-2));
        border-color: transparent;
      }

      @media (max-width: 720px) {
        .app-topbar { padding: 0.9rem 1rem; }
        .profile-grid { grid-template-columns: 1fr !important; }
        .profile-grid > * { order: 0 !important; }
      }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <header class="app-topbar">
        <a class="app-brand" href="/">
          <div class="app-brand-mark">OS</div>
          <div class="app-brand-copy">
            <div class="app-brand-title">OpenSchedule</div>
          </div>
        </a>
        <div class="app-topbar-actions">
          <slot name="header-actions" />
          <button class="hamburger" id="hamburger-btn" aria-label="Menu">☰</button>
          <div class="nav-drawer" id="nav-drawer">
            {session && (
              <>
                {session.role === "admin" && (
                  <a href="/hosts/me" class="nav-link">Admin</a>
                )}
                {(session.role === "host" || session.role === "admin") && (
                  <a href="/hosts/me" class="nav-link">My Profile</a>
                )}
                <form method="POST" action="/api/auth/logout" style="display:inline;">
                  <button type="submit" class="nav-link" style="border:none;background:none;cursor:pointer;width:100%;text-align:left;">
                    Log out →
                  </button>
                </form>
              </>
            )}
          </div>
        </div>
      </header>
      <main class="app-page">
        <slot />
      </main>
    </div>
    <script>
      const btn = document.getElementById("hamburger-btn");
      const drawer = document.getElementById("nav-drawer");
      btn?.addEventListener("click", () => drawer?.classList.toggle("open"));
      // Close on outside click
      document.addEventListener("click", (e) => {
        if (drawer?.classList.contains("open") && !btn?.contains(e.target as Node) && !drawer?.contains(e.target as Node)) {
          drawer.classList.remove("open");
        }
      });
    </script>
  </body>
</html>
