---
export interface Props {
  name: string;
  type?: string;
  label: string;
  required?: boolean;
  placeholder?: string;
  value?: string;
  style?: string;
}

const { name, type = "text", label, required, placeholder, value, style } = Astro.props;
---

<div style="display: grid; gap: 0.3rem;">
  <label for={name} style="font-size: 0.82rem; color: var(--app-text-muted);">{label}</label>
  <input
    id={name}
    name={name}
    type={type}
    required={required}
    placeholder={placeholder}
    value={value}
    style={`width:100%; padding:0.55rem 0.75rem; border-radius:0.7rem; border:1px solid var(--app-border); background:rgba(0,0,0,0.2); color:#fff; font-size:0.88rem; outline:none; ${style || ""}`}
  />
</div>
