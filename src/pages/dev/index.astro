---
import AppLayout from "@/layouts/app-layout.astro";
import { TimezonePicker } from "@/host-dashboard/timezone-picker";
import { FuzzySearch } from "@/ui/fuzzy-search";

const isDev = import.meta.env.DEV;
if (!isDev) return Astro.redirect("/");

const sections = ["buttons", "inputs", "cards", "badges", "breadcrumbs", "typography", "dropdowns", "fuzzy-search", "timezone-picker", "forms"];
---

<AppLayout title="Dev UI — OpenSchedule">
  <style is:global>
    .dev-sidebar { position: sticky; top: 6rem; }
    .dev-sidebar a { display: block; padding: 0.35rem 0.75rem; border-radius: 0.4rem; font-size: 0.85rem; color: var(--app-text-muted); text-decoration: none; }
    .dev-sidebar a:hover { background: rgba(255,255,255,0.04); color: var(--app-text); }
    .dev-section { scroll-margin-top: 5rem; }
  </style>
  <div style="display: grid; grid-template-columns: 180px 1fr; max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; gap: 2rem;">
    <!-- Sidebar -->
    <div class="dev-sidebar">
      <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
        <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:0.2rem 0.45rem;border-radius:0.25rem;background:rgba(255,200,0,0.15);color:#fbbf24;">DEV</span>
        <span style="font-size:0.82rem;font-weight:600;">UI Library</span>
      </div>
      {sections.map((s) => <a href={"#"+s}>{s.replace(/-/g," ")}</a>)}
    </div>

    <!-- Content -->
    <div>
      <!-- Breadcrumbs -->
      <div id="breadcrumbs" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Breadcrumbs</h2>
        <nav style="display:flex;gap:0.4rem;align-items:center;font-size:0.85rem;color:var(--app-text-muted);">
          <a href="#" style="color:var(--app-primary);text-decoration:none;">Home</a>
          <span>/</span>
          <a href="#" style="color:var(--app-text-muted);text-decoration:none;">Settings</a>
          <span>/</span>
          <span style="color:var(--app-text);">Profile</span>
        </nav>
        <div style="margin-top:0.5rem;font-size:0.82rem;color:var(--app-text-muted);">Usage: <code style="color:var(--app-primary);">nav > a + span / span</code></div>
      </div>

      <!-- Buttons -->
      <div id="buttons" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Buttons</h2>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
          <button class="app-btn">Secondary</button>
          <button class="app-btn app-btn-primary">Primary</button>
          <button class="app-btn app-btn-outline">Outline</button>
          <button class="app-btn" disabled>Disabled</button>
          <button class="app-btn app-btn-primary" disabled>Disabled Primary</button>
          <a href="#" class="app-btn">Link as Button</a>
          <a href="#" class="app-btn app-btn-primary">Primary Link</a>
        </div>
      </div>

      <!-- Inputs -->
      <div id="inputs" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Inputs</h2>
        <div style="display:grid;gap:0.75rem;max-width:360px;">
          <div style="display:grid;gap:0.3rem;">
            <label style="font-size:0.82rem;color:var(--app-text-muted);">Text Input</label>
            <input type="text" placeholder="Placeholder"
              style="width:100%;padding:0.55rem 0.75rem;border-radius:0.7rem;border:1px solid var(--app-border);background:rgba(0,0,0,0.2);color:#fff;font-size:0.88rem;outline:none;" />
          </div>
          <div style="display:grid;gap:0.3rem;">
            <label style="font-size:0.82rem;color:var(--app-text-muted);">Email</label>
            <input type="email" placeholder="you@example.com"
              style="width:100%;padding:0.55rem 0.75rem;border-radius:0.7rem;border:1px solid var(--app-border);background:rgba(0,0,0,0.2);color:#fff;font-size:0.88rem;outline:none;" />
          </div>
        </div>
      </div>

      <!-- Cards -->
      <div id="cards" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Cards</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div style="padding:1.5rem;border-radius:0.85rem;border:1px solid var(--app-border);background:rgba(255,255,255,0.02);">
            <h3 style="margin:0 0 0.35rem;font-size:0.95rem;font-weight:700;">Default Card</h3>
            <p style="margin:0;font-size:0.85rem;color:var(--app-text-muted);">Standard card surface.</p>
          </div>
          <div style="padding:1.5rem;border-radius:0.85rem;border:1px solid var(--app-border);background:rgba(99,102,241,0.04);">
            <h3 style="margin:0 0 0.35rem;font-size:0.95rem;font-weight:700;">Tinted</h3>
            <p style="margin:0;font-size:0.85rem;color:var(--app-text-muted);">Indigo tint background.</p>
          </div>
          <div style="padding:1rem;border-radius:0.7rem;border:1px solid var(--app-border);">
            <h3 style="margin:0 0 0.35rem;font-size:0.9rem;font-weight:600;">Compact</h3>
            <p style="margin:0;font-size:0.82rem;color:var(--app-text-muted);">Smaller padding.</p>
          </div>
          <div style="padding:1.5rem;border-radius:0.85rem;border:1px dashed var(--app-border);">
            <h3 style="margin:0 0 0.35rem;font-size:0.95rem;font-weight:700;">Dashed</h3>
            <p style="margin:0;font-size:0.85rem;color:var(--app-text-muted);">For add/empty states.</p>
          </div>
        </div>
      </div>

      <!-- Badges -->
      <div id="badges" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Badges</h2>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          <span style="padding:0.25rem 0.6rem;border-radius:999px;border:1px solid var(--app-border);font-size:0.78rem;color:var(--app-text-muted);">Default</span>
          <span style="padding:0.25rem 0.6rem;border-radius:999px;background:rgba(99,102,241,0.12);border:1px solid rgba(99,102,241,0.2);font-size:0.78rem;color:var(--app-primary);">Primary</span>
          <span style="padding:0.25rem 0.6rem;border-radius:999px;background:rgba(52,211,153,0.12);border:1px solid rgba(52,211,153,0.2);font-size:0.78rem;color:#34d399;">Success</span>
          <span style="padding:0.25rem 0.6rem;border-radius:999px;background:rgba(248,113,113,0.12);border:1px solid rgba(248,113,113,0.2);font-size:0.78rem;color:#f87171;">Error</span>
          <span style="padding:0.25rem 0.6rem;border-radius:999px;background:rgba(251,191,36,0.12);border:1px solid rgba(251,191,36,0.2);font-size:0.78rem;color:#fbbf24;">Warning</span>
        </div>
      </div>

      <!-- Typography -->
      <div id="typography" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Typography</h2>
        <div style="display:grid;gap:0.4rem;">
          <div style="font-size:2rem;font-weight:800;letter-spacing:-0.03em;">Heading 1 / 2rem 800</div>
          <div style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;">Heading 2 / 1.5rem 800</div>
          <div style="font-size:1.25rem;font-weight:700;">Heading 3 / 1.25rem 700</div>
          <div style="font-size:1rem;font-weight:700;">Heading 4 / 1rem 700</div>
          <div style="font-size:0.95rem;color:var(--app-text-muted);">Body text. Montserrat at 0.95rem in muted color for descriptions.</div>
          <div style="font-size:0.82rem;color:var(--app-text-muted);">Small / labels / timestamps — 0.82rem.</div>
          <code style="font-size:0.82rem;color:var(--app-primary);">code { font-size: 0.82rem; }</code>
        </div>
      </div>

      <!-- Dropdown (rendered) -->
      <div id="dropdowns" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Dropdown</h2>
        <div style="max-width:240px;">
          <div class="app-btn" style="justify-content:space-between;">
            <span>Click me</span>
            <span style="font-size:0.7rem;">▼</span>
          </div>
          <p style="font-size:0.82rem;color:var(--app-text-muted);margin-top:0.4rem;">Interactive dropdown via <code>ui/dropdown.tsx</code> — wraps any trigger + any content with outside-click close.</p>
        </div>
      </div>

      <!-- Fuzzy Search -->
      <div id="fuzzy-search" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Fuzzy Search</h2>
        <div style="max-width:320px;">
          <FuzzySearch
            items={["Apple", "Apricot", "Avocado", "Banana", "Blackberry", "Blueberry", "Cherry", "Date", "Elderberry", "Fig", "Grape", "Grapefruit", "Kiwi", "Lemon", "Mango", "Orange", "Papaya", "Peach", "Pear", "Pineapple", "Plum", "Raspberry", "Strawberry", "Watermelon"]}
            value=""
            placeholder="Search fruit…"
            client:load
          />
          <p style="font-size:0.82rem;color:var(--app-text-muted);margin-top:0.4rem;">Reusable fuzzy search via <code>ui/fuzzy-search.tsx</code>. Uses <code>Dropdown</code> internally.</p>
        </div>
      </div>

      <!-- Timezone Picker -->
      <div id="timezone-picker" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Timezone Picker</h2>
        <div style="max-width:320px;">
          <TimezonePicker value="America/New_York" client:load />
          <p style="font-size:0.82rem;color:var(--app-text-muted);margin-top:0.4rem;">Wraps <code>FuzzySearch</code> with all IANA timezones. Auto-detects browser timezone.</p>
        </div>
      </div>

      <!-- Forms -->
      <div id="forms" class="dev-section" style="margin-bottom:2.5rem;">
        <h2 style="font-size:1rem;font-weight:700;margin:0 0 0.75rem;">Form Example</h2>
        <div style="max-width:360px;padding:1.5rem;border-radius:0.85rem;border:1px solid var(--app-border);background:rgba(255,255,255,0.02);display:grid;gap:0.75rem;">
          <h3 style="margin:0;font-size:1rem;font-weight:700;">Edit Profile</h3>
          <div style="display:grid;gap:0.3rem;">
            <label style="font-size:0.82rem;color:var(--app-text-muted);">Name</label>
            <input type="text" value="Michael ONeal"
              style="width:100%;padding:0.55rem 0.75rem;border-radius:0.7rem;border:1px solid var(--app-border);background:rgba(0,0,0,0.2);color:#fff;font-size:0.88rem;outline:none;" />
          </div>
          <div style="display:grid;gap:0.3rem;">
            <label style="font-size:0.82rem;color:var(--app-text-muted);">Email</label>
            <input type="email" value="augmentedmike@gmail.com"
              style="width:100%;padding:0.55rem 0.75rem;border-radius:0.7rem;border:1px solid var(--app-border);background:rgba(0,0,0,0.2);color:#fff;font-size:0.88rem;outline:none;" />
          </div>
          <div style="display:flex;gap:0.5rem;justify-content:flex-end;">
            <button class="app-btn" style="padding:0.5rem 1rem;min-height:0;font-size:0.85rem;">Cancel</button>
            <button class="app-btn app-btn-primary" style="padding:0.5rem 1rem;min-height:0;font-size:0.85rem;">Save</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</AppLayout>
