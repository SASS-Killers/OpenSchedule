---
import AppLayout from "@/layouts/app-layout.astro";

// Only available in dev — block in production
const isDev = import.meta.env.DEV;
if (!isDev) return Astro.redirect("/");
---

<AppLayout title="Dev UI — OpenSchedule">
  <section style="padding: 2rem 1.5rem; max-width: 800px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
      <span style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.25rem 0.5rem; border-radius: 0.3rem; background: rgba(255,200,0,0.15); color: #fbbf24;">DEV</span>
      <h1 style="margin: 0; font-size: 1.25rem; font-weight: 700;">UI Component Library</h1>
    </div>

    <!-- Buttons -->
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem;">Buttons</h2>
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <button class="app-btn">Secondary</button>
        <button class="app-btn app-btn-primary">Primary</button>
        <button class="app-btn" disabled>Disabled</button>
        <button class="app-btn app-btn-primary" disabled>Disabled Primary</button>
        <button class="app-btn" style="justify-content: center; width: 160px;">
          <span style="display:inline-flex;gap:0.35rem;align-items:center;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            With Icon
          </span>
        </button>
        <a href="#" class="app-btn">Link Button</a>
        <a href="#" class="app-btn app-btn-primary">Primary Link</a>
      </div>
    </div>

    <!-- Inputs -->
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem;">Inputs</h2>
      <div style="display: grid; gap: 0.75rem; max-width: 360px;">
        <div style="display: grid; gap: 0.3rem;">
          <label style="font-size: 0.82rem; color: var(--app-text-muted);">Text Input</label>
          <input type="text" placeholder="Placeholder text"
            style="width:100%; padding:0.55rem 0.75rem; border-radius:0.7rem; border:1px solid var(--app-border); background:rgba(0,0,0,0.2); color:#fff; font-size:0.88rem; outline:none;" />
        </div>
        <div style="display: grid; gap: 0.3rem;">
          <label style="font-size: 0.82rem; color: var(--app-text-muted);">Email</label>
          <input type="email" placeholder="you@example.com"
            style="width:100%; padding:0.55rem 0.75rem; border-radius:0.7rem; border:1px solid var(--app-border); background:rgba(0,0,0,0.2); color:#fff; font-size:0.88rem; outline:none;" />
        </div>
        <div style="display: grid; gap: 0.3rem;">
          <label style="font-size: 0.82rem; color: var(--app-text-muted);">Select</label>
          <select
            style="width:100%; padding:0.55rem 0.75rem; border-radius:0.7rem; border:1px solid var(--app-border); background:rgba(0,0,0,0.2); color:#fff; font-size:0.88rem; outline:none;">
            <option>Option 1</option>
            <option>Option 2</option>
            <option>Option 3</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Cards / Surfaces -->
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem;">Cards</h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div style="padding: 1.5rem; border-radius: 0.85rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02);">
          <h3 style="margin:0 0 0.35rem; font-size:0.95rem; font-weight:700;">Card Title</h3>
          <p style="margin:0; font-size:0.85rem; color:var(--app-text-muted);">This is a standard card surface used throughout the app.</p>
        </div>
        <div style="padding: 1.5rem; border-radius: 0.85rem; border: 1px solid var(--app-border); background: rgba(99,102,241,0.04);">
          <h3 style="margin:0 0 0.35rem; font-size:0.95rem; font-weight:700;">Tinted Card</h3>
          <p style="margin:0; font-size:0.85rem; color:var(--app-text-muted);">Card with an indigo tint background.</p>
        </div>
        <div style="padding: 1rem; border-radius: 0.7rem; border: 1px solid var(--app-border);">
          <h3 style="margin:0 0 0.35rem; font-size:0.9rem; font-weight:600;">Compact Card</h3>
          <p style="margin:0; font-size:0.82rem; color:var(--app-text-muted);">Smaller padding for dense layouts.</p>
        </div>
        <div style="padding: 1.5rem; border-radius: 0.85rem; border: 1px dashed var(--app-border);">
          <h3 style="margin:0 0 0.35rem; font-size:0.95rem; font-weight:700;">Dashed Card</h3>
          <p style="margin:0; font-size:0.85rem; color:var(--app-text-muted);">For add/empty state cards.</p>
        </div>
      </div>
    </div>

    <!-- Badges / Pills -->
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem;">Badges</h2>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <span style="padding:0.25rem 0.6rem; border-radius:999px; border:1px solid var(--app-border); font-size:0.78rem; color:var(--app-text-muted);">Default</span>
        <span style="padding:0.25rem 0.6rem; border-radius:999px; background:rgba(99,102,241,0.12); border:1px solid rgba(99,102,241,0.2); font-size:0.78rem; color:var(--app-primary);">Primary</span>
        <span style="padding:0.25rem 0.6rem; border-radius:999px; background:rgba(52,211,153,0.12); border:1px solid rgba(52,211,153,0.2); font-size:0.78rem; color:#34d399;">Green</span>
        <span style="padding:0.25rem 0.6rem; border-radius:999px; background:rgba(248,113,113,0.12); border:1px solid rgba(248,113,113,0.2); font-size:0.78rem; color:#f87171;">Red</span>
      </div>
    </div>

    <!-- Sections / Dividers -->
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem;">Section Dividers</h2>
      <div style="background: rgba(255,255,255,0.015); padding: 1.5rem; border-radius: 0.5rem;">
        <p style="margin:0; font-size:0.85rem; color:var(--app-text-muted);">Tinted background section (alternating sections use this)</p>
      </div>
      <div style="border-top: 1px solid var(--app-border); margin: 1rem 0;"></div>
      <p style="margin:0; font-size:0.85rem; color:var(--app-text-muted);">Horizontal rule with border-subtle color</p>
    </div>

    <!-- Typography -->
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem;">Typography</h2>
      <div style="display: grid; gap: 0.5rem;">
        <h1 style="margin:0; font-size:2rem; font-weight:800; letter-spacing:-0.03em;">Heading 1</h1>
        <h2 style="margin:0; font-size:1.5rem; font-weight:800; letter-spacing:-0.03em;">Heading 2</h2>
        <h3 style="margin:0; font-size:1.15rem; font-weight:700;">Heading 3</h3>
        <p style="margin:0; font-size:0.95rem; color:var(--app-text-muted);">Body text with muted color for descriptions and supporting content.</p>
        <p style="margin:0; font-size:0.82rem; color:var(--app-text-muted);">Small text — labels, timestamps, secondary info.</p>
        <code style="font-size:0.82rem; color:var(--app-primary);">code / monospace</code>
      </div>
    </div>

    <!-- Navigation -->
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem;">Navigation Links</h2>
      <div style="display: flex; gap: 1rem; align-items: center;">
        <span class="nav-link">Nav Link</span>
        <span class="nav-link" style="color:var(--app-primary);">Active</span>
      </div>
    </div>

    <!-- Full Example: Form Card -->
    <div style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.75rem;">Example: Form in a Card</h2>
      <div style="max-width: 360px; padding: 1.5rem; border-radius: 0.85rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02); display: grid; gap: 0.75rem;">
        <h3 style="margin:0; font-size:1rem; font-weight:700;">Edit Profile</h3>
        <div style="display:grid; gap:0.3rem;">
          <label style="font-size:0.82rem; color:var(--app-text-muted);">Name</label>
          <input type="text" value="Michael ONeal"
            style="width:100%; padding:0.55rem 0.75rem; border-radius:0.7rem; border:1px solid var(--app-border); background:rgba(0,0,0,0.2); color:#fff; font-size:0.88rem; outline:none;" />
        </div>
        <div style="display:grid; gap:0.3rem;">
          <label style="font-size:0.82rem; color:var(--app-text-muted);">Email</label>
          <input type="email" value="augmentedmike@gmail.com"
            style="width:100%; padding:0.55rem 0.75rem; border-radius:0.7rem; border:1px solid var(--app-border); background:rgba(0,0,0,0.2); color:#fff; font-size:0.88rem; outline:none;" />
        </div>
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
          <button class="app-btn" style="padding:0.5rem 1rem; min-height:0; font-size:0.85rem;">Cancel</button>
          <button class="app-btn app-btn-primary" style="padding:0.5rem 1rem; min-height:0; font-size:0.85rem;">Save</button>
        </div>
      </div>
    </div>
  </section>
</AppLayout>
