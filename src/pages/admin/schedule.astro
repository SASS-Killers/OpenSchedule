---
import AppLayout from "@/layouts/AppLayout.astro";
import { requireSession } from "@/lib/auth-guard";
import { env } from "cloudflare:workers";
import { ScheduleEditor } from "@/components/ScheduleEditor";

const session = await requireSession(Astro.request);
if (!session || !["admin", "host"].includes(session.role)) return Astro.redirect("/login");

const db = env.DB as D1Database;
const rows = await db
  .prepare("SELECT day_of_week, start_time, end_time FROM schedules WHERE user_id = ? ORDER BY day_of_week")
  .bind(session.userId)
  .all();

const initial = (rows.results as { day_of_week: number; start_time: string; end_time: string }[]).map(
  (r) => ({ dayOfWeek: r.day_of_week, startTime: r.start_time, endTime: r.end_time })
);
---

<AppLayout title="Schedule — OpenSchedule">
  <section style="padding: 2rem 1.5rem; max-width: 800px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
      <a href="/admin" class="app-btn" style="padding: 0.5rem 1rem; font-size: 0.85rem;">← Back</a>
      <h1 style="margin: 0; font-size: 1.25rem; font-weight: 700;">Availability Schedule</h1>
    </div>

    <div style="
      display: grid; gap: 0.75rem;
      padding: 2rem; border-radius: 0.85rem;
      border: 1px solid var(--app-border);
      background: rgba(255,255,255,0.02);
    ">
      <p style="margin: 0; font-size: 0.9rem; color: var(--app-text-muted);">
        Click a day to toggle it on or off. Set your hours, then save.
      </p>

      <ScheduleEditor initial={initial} client:load />
    </div>
  </section>
</AppLayout>
