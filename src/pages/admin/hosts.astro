---
import AppLayout from "@/layouts/AppLayout.astro";
import { requireSession } from "@/lib/auth-guard";

const session = await requireSession(Astro.request);
if (!session || !["admin", "host"].includes(session.role)) return Astro.redirect("/login");
---

<AppLayout title="Team — OpenSchedule">
  <section style="padding: 2rem 1.5rem; max-width: 720px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
      <a href="/admin" class="app-btn" style="padding: 0.5rem 1rem; font-size: 0.85rem;">← Back</a>
      <h1 style="margin: 0; font-size: 1.25rem; font-weight: 700;">Team Members</h1>
    </div>

    <div style="
      display: grid; gap: 0.75rem;
      padding: 2rem; border-radius: 0.85rem;
      border: 1px solid var(--app-border);
      background: rgba(255,255,255,0.02);
    ">
      <div style="
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.75rem; border-radius: 0.5rem;
        border: 1px solid var(--app-border);
      ">
        <div style="
          width: 2.25rem; height: 2.25rem; border-radius: 999px;
          background: linear-gradient(135deg, var(--app-primary), var(--app-primary-2));
          display: grid; place-items: center;
          font-weight: 700; font-size: 0.85rem; color: #fff;
        ">MO</div>
        <div style="flex: 1;">
          <div style="font-weight: 600; font-size: 0.92rem;">Michael ONeal</div>
          <div style="font-size: 0.8rem; color: var(--app-text-muted);">augmentedmike@gmail.com</div>
        </div>
        <span style="
          font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
          padding: 0.25rem 0.6rem; border-radius: 999px;
          background: rgba(99, 102, 241, 0.15); color: #a5b4fc;
        ">Admin</span>
      </div>

      <div style="
        display: flex; align-items: center; justify-content: center;
        padding: 2rem; border-radius: 0.5rem;
        border: 1px dashed var(--app-border);
        color: var(--app-text-muted); font-size: 0.9rem;
        cursor: pointer;
      ">+ Add Host</div>
    </div>
  </section>
</AppLayout>
