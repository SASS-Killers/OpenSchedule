---
import AppLayout from "@/layouts/AppLayout.astro";
---

<AppLayout title="Sign In — OpenSchedule">
  <section style="
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 1.5rem;
    gap: 1.5rem;
  ">
    <h1 style="
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin: 0;
    ">Sign In</h1>
    <p style="
      font-size: 0.95rem;
      color: var(--app-text-muted);
      max-width: 360px;
      line-height: 1.6;
      margin: 0;
    ">Enter your email to receive a one-time login code. No password needed.</p>
    <form method="POST" action="/api/auth/send-code" style="
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      width: 100%;
      max-width: 320px;
    ">
      <input
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        style="
          padding: 0.75rem 1rem;
          border-radius: 0.85rem;
          border: 1px solid var(--app-border);
          background: rgba(255,255,255,0.03);
          color: #fff;
          font-size: 0.95rem;
          outline: none;
        "
      />
      <button type="submit" class="app-btn app-btn-primary" style="justify-content: center;">
        Send Login Code
      </button>
    </form>
  </section>
</AppLayout>
