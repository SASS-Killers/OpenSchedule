---
import AppLayout from "@/layouts/app-layout.astro";
import { Form } from "@/ui/form";
---

<AppLayout title="Sign In — OpenSchedule">
  <section style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 6rem 1.5rem; gap: 1.5rem;">
    <h1 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.03em; margin: 0;">Sign In</h1>

    <div id="step-email" style="display: flex; flex-direction: column; gap: 0.75rem; width: 100%; max-width: 320px;">
      <Form
        fields={[{ name: "email", label: "", type: "email", placeholder: "you@example.com", required: true }]}
        submitLabel="Send Login Code"
        client:load
        onSubmit={async (values) => {
          const res = await fetch("/api/auth/send-code", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: `email=${encodeURIComponent(values.email)}`,
          });
          const data = await res.json();
          if (data.ok) return { ok: true, data };
          return { ok: false, error: "Email not recognized." };
        }}
        onSuccess={(data) => {
          if (data.devCode) (document.getElementById("code-input") as HTMLInputElement).value = data.devCode;
          document.getElementById("step-email")!.style.display = "none";
          document.getElementById("step-code")!.style.display = "flex";
          document.getElementById("code-input")!.focus();
        }}
      />
    </div>

    <div id="step-code" style="display: none; flex-direction: column; gap: 0.75rem; width: 100%; max-width: 320px;">
      <p style="font-size: 0.9rem; color: var(--app-text-muted); margin: 0;">Check your email for the login code, then enter it below.</p>
      <Form
        fields={[{ name: "code", label: "", type: "text", placeholder: "000000", required: true }]}
        submitLabel="Verify & Sign In"
        client:load
        onSubmit={async (values) => {
          const email = (document.getElementById("step-email") as any)?.__email || "";
          const res = await fetch("/pgrst/rpc/verify_code", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ p_email: email, p_code: values.code }),
          });
          const data = await res.json();
          if (data.userId) return { ok: true, data };
          return { ok: false, error: data.error || "Verification failed" };
        }}
        onSuccess={(data) => {
          const form = document.createElement("form");
          form.method = "POST";
          form.action = "/api/auth/session";
          for (const key of ["userId", "email", "name", "role"]) {
            const input = document.createElement("input");
            input.type = "hidden";
            input.name = key;
            input.value = data[key] || "";
            form.appendChild(input);
          }
          document.body.appendChild(form);
          form.submit();
        }}
      />
      <button id="back-btn" class="app-btn" style="justify-content: center; width: 100%;">Use a different email</button>
    </div>
  </section>
</AppLayout>

<script>
// Track email across the two forms
const emailForm = document.querySelector("#step-email .app-btn-primary");
if (emailForm) {
  const emailInput = document.querySelector<HTMLInputElement>("#step-email input");
  document.getElementById("step-email")!.addEventListener("submit", () => {
    (document.getElementById("step-email") as any).__email = emailInput?.value || "";
  });
}

document.getElementById("back-btn")!.addEventListener("click", () => {
  document.getElementById("step-email")!.style.display = "flex";
  document.getElementById("step-code")!.style.display = "none";
});
</script>
