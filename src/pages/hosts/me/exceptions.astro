---
import AppLayout from "@/layouts/app-layout.astro";
import { requireSession } from "@/lib/auth-guard";
import { ExceptionManager } from "@/host-dashboard/exception-manager";

const session = await requireSession(Astro.request);
if (!session || !["admin", "host"].includes(session.role)) return Astro.redirect("/login");
---

<AppLayout title="Exceptions — OpenSchedule">
  <section style="max-width: 640px; margin: 0 auto; padding: 2rem 1.5rem;">
    <a href="/hosts/me" style="display: inline-block; font-size: 0.85rem; color: var(--app-text-muted); margin-bottom: 1rem; text-decoration: none;">← Back to Settings</a>
    <ExceptionManager client:load />
  </section>
</AppLayout>
