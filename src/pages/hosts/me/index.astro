---
import AppLayout from "@/layouts/AppLayout.astro";
import { requireSession } from "@/lib/auth-guard";
import { query } from "@/db/neon";
import { Avatar } from "@/components/Avatar";

const session = await requireSession(Astro.request);
if (!session || !["admin", "host"].includes(session.role)) return Astro.redirect("/login");

const [user] = await query`
  SELECT slug FROM users WHERE id = ${session.userId} LIMIT 1
` as any[];
---

<AppLayout title="My Settings — OpenSchedule">
  <section style="padding: 2rem 1.5rem; max-width: 600px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
      <Avatar userId={session.userId} name={session.name} client:load />
      <div>
        <h1 style="margin: 0; font-size: 1.25rem; font-weight: 700;">{session.name}</h1>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted);">{session.email}</p>
      </div>
    </div>

    <div style="display: grid; gap: 0.75rem; margin-bottom: 1.5rem;">
      <label class="app-btn" style="justify-content: center; cursor: pointer;">
        Upload Avatar
        <input type="file" id="avatar-input" accept="image/png,image/jpeg,image/gif,image/webp" style="display: none;" />
      </label>
      <div id="avatar-status" style="font-size: 0.82rem; color: var(--app-text-muted); text-align: center;"></div>
    </div>

    <div style="display: grid; gap: 0.75rem;">
      <a href="/hosts/me/event-types" class="app-btn" style="justify-content: flex-start; padding: 1rem; text-decoration: none;">
        <span style="font-weight: 600;">Event Types</span>
        <span style="margin-left: auto; font-size: 0.85rem; color: var(--app-text-muted);">Meeting types you offer →</span>
      </a>
      <a href="/hosts/me/schedule" class="app-btn" style="justify-content: flex-start; padding: 1rem; text-decoration: none;">
        <span style="font-weight: 600;">Schedule</span>
        <span style="margin-left: auto; font-size: 0.85rem; color: var(--app-text-muted);">Your availability →</span>
      </a>
      {user && (
        <a href={`/hosts/${user.slug}`} target="_blank" class="app-btn" style="justify-content: flex-start; padding: 1rem; text-decoration: none;">
          <span style="font-weight: 600;">View Your Profile</span>
          <span style="margin-left: auto; font-size: 0.85rem; color: var(--app-text-muted);">Open in new tab →</span>
        </a>
      )}
    </div>
  </section>
</AppLayout>

<script>
const input = document.getElementById("avatar-input")!;
const status = document.getElementById("avatar-status")!;

input.addEventListener("change", async () => {
  const file = input.files?.[0];
  if (!file) return;

  status.textContent = "Processing...";

  // Resize to 200x200 on the client
  const canvas = document.createElement("canvas");
  canvas.width = 200;
  canvas.height = 200;
  const ctx = canvas.getContext("2d")!;
  const url = URL.createObjectURL(file);

  await new Promise<void>((resolve) => {
    const image = new Image();
    image.onload = () => {
      ctx.drawImage(image, 0, 0, 200, 200);
      URL.revokeObjectURL(url);
      resolve();
    };
    image.src = url;
  });

  const dataUrl = canvas.toDataURL("image/png");

  const res = await fetch("/api/avatar", {
    method: "POST",
    headers: { "content-type": "application/json" },
    body: JSON.stringify({ data: dataUrl }),
  });

  if (res.ok) {
    // Trigger avatar component to reload
    if ((window as any).__avatarReload) (window as any).__avatarReload();
    status.textContent = "Avatar updated.";
  } else {
    const err = await res.json();
    status.textContent = err.error || "Upload failed.";
  }
});
</script>
