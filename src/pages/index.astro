---
import AppLayout from "@/layouts/AppLayout.astro";
---

<AppLayout title="OpenSchedule — Free, Self-Hosted Calendly Replacement">
  <!-- Hero -->
  <section style="padding: 6rem 1.5rem 4rem; max-width: 960px; margin: 0 auto; text-align: center;">
    <div style="display: inline-flex; gap: 0.4rem; align-items: center; padding: 0.35rem 0.85rem; border-radius: 999px; border: 1px solid rgba(99,102,241,0.25); background: rgba(99,102,241,0.08); font-size: 0.8rem; color: var(--app-primary); font-weight: 500; margin-bottom: 2rem;">
      <span style="width: 0.5rem; height: 0.5rem; border-radius: 999px; background: #34d399; display: inline-block;"></span>
      Self-hosted. Free forever. Open source.
    </div>

    <h1 style="font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 auto 1rem; line-height: 1.1; max-width: 720px;">
      Replace Calendly with<br/>
      <span style="background: linear-gradient(135deg, var(--app-primary), var(--app-primary-2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">your own database</span>
    </h1>
    <p style="font-size: 1.1rem; color: var(--app-text-muted); max-width: 520px; margin: 0 auto 2rem; line-height: 1.7;">
      OpenSchedule is a free, self-hosted scheduling platform. No subscriptions, no third-party servers processing your clients' data. Just PostgreSQL and serverless functions.
    </p>

    <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
      <a href="/login" class="app-btn app-btn-primary" style="padding: 0.9rem 2.25rem; font-weight: 600; font-size: 1rem;">Get Started Free</a>
      <a href="https://github.com/SASS-Killers/OpenSchedule" target="_blank" class="app-btn" style="padding: 0.9rem 2.25rem; font-weight: 600; font-size: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        Star on GitHub
      </a>
    </div>
  </section>

  <!-- Feature Grid (Bento) -->
  <section style="padding: 2rem 1.5rem 5rem; max-width: 960px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div style="padding: 2rem; border-radius: 1rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02);">
        <div style="width: 2.5rem; height: 2.5rem; border-radius: 0.65rem; background: rgba(99,102,241,0.12); display: grid; place-items: center; margin-bottom: 1rem; color: var(--app-primary); font-size: 1.25rem;">💰</div>
        <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">Free Forever</h3>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">No paid tiers, no hidden costs. Runs on free-tier Neon PostgreSQL and Cloudflare.</p>
      </div>
      <div style="padding: 2rem; border-radius: 1rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02);">
        <div style="width: 2.5rem; height: 2.5rem; border-radius: 0.65rem; background: rgba(99,102,241,0.12); display: grid; place-items: center; margin-bottom: 1rem; color: var(--app-primary); font-size: 1.25rem;">🔒</div>
        <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">Your Data Stays Yours</h3>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Self-hosted on your infrastructure. No third-party scheduling servers touching your clients' information.</p>
      </div>
      <div style="padding: 2rem; border-radius: 1rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02);">
        <div style="width: 2.5rem; height: 2.5rem; border-radius: 0.65rem; background: rgba(99,102,241,0.12); display: grid; place-items: center; margin-bottom: 1rem; color: var(--app-primary); font-size: 1.25rem;">👥</div>
        <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">Multi-User</h3>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Admin provisions hosts. Hosts configure availability. Clients book. All in one system.</p>
      </div>
      <div style="padding: 2rem; border-radius: 1rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02); grid-column: span 2; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          <div style="width: 2.5rem; height: 2.5rem; border-radius: 0.65rem; background: rgba(99,102,241,0.12); display: grid; place-items: center; margin-bottom: 1rem; color: var(--app-primary); font-size: 1.25rem;">🚀</div>
          <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">No Lock-In</h3>
          <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Everything runs on PostgreSQL. Migrate your data any time. Open source — you own the code.</p>
        </div>
        <div>
          <div style="width: 2.5rem; height: 2.5rem; border-radius: 0.65rem; background: rgba(99,102,241,0.12); display: grid; place-items: center; margin-bottom: 1rem; color: var(--app-primary); font-size: 1.25rem;">⚡</div>
          <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">One-Command Deploy</h3>
          <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Deploy on any free VPS with a single curl command. Including Oracle Cloud, GCP, AWS free tiers.</p>
        </div>
      </div>
      <div style="padding: 2rem; border-radius: 1rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02);">
        <div style="width: 2.5rem; height: 2.5rem; border-radius: 0.65rem; background: rgba(99,102,241,0.12); display: grid; place-items: center; margin-bottom: 1rem; color: var(--app-primary); font-size: 1.25rem;">📅</div>
        <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">Smart Scheduling</h3>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Weekly hours, date overrides, buffers, minimum notice. Double-booking protection built in.</p>
      </div>
      <div style="padding: 2rem; border-radius: 1rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02);">
        <div style="width: 2.5rem; height: 2.5rem; border-radius: 0.65rem; background: rgba(99,102,241,0.12); display: grid; place-items: center; margin-bottom: 1rem; color: var(--app-primary); font-size: 1.25rem;">🔑</div>
        <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">Passwordless Auth</h3>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Secure OTP codes via email. No passwords to manage, leak, or reset.</p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section style="padding: 2rem 1.5rem 5rem; max-width: 960px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 2.5rem;">
      <div style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--app-primary); margin-bottom: 0.5rem;">How It Works</div>
      <h2 style="font-size: 1.75rem; font-weight: 800; margin: 0;">From zero to booked in minutes</h2>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
      <div style="text-align: center; padding: 2rem 1rem;">
        <div style="width: 3.5rem; height: 3.5rem; border-radius: 999px; background: rgba(99,102,241,0.1); display: grid; place-items: center; margin: 0 auto 1rem; font-weight: 800; font-size: 1.2rem; color: var(--app-primary);">1</div>
        <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">Deploy</h3>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Run one command on any VPS or local machine. PostgreSQL handles everything.</p>
      </div>
      <div style="text-align: center; padding: 2rem 1rem; position: relative;">
        <div style="width: 3.5rem; height: 3.5rem; border-radius: 999px; background: rgba(99,102,241,0.1); display: grid; place-items: center; margin: 0 auto 1rem; font-weight: 800; font-size: 1.2rem; color: var(--app-primary);">2</div>
        <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">Configure</h3>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Set your availability. Create event types. Share your booking link.</p>
      </div>
      <div style="text-align: center; padding: 2rem 1rem;">
        <div style="width: 3.5rem; height: 3.5rem; border-radius: 999px; background: rgba(99,102,241,0.1); display: grid; place-items: center; margin: 0 auto 1rem; font-weight: 800; font-size: 1.2rem; color: var(--app-primary);">3</div>
        <h3 style="margin: 0 0 0.35rem; font-size: 1rem; font-weight: 700;">Get Booked</h3>
        <p style="margin: 0; font-size: 0.85rem; color: var(--app-text-muted); line-height: 1.6;">Clients see your available slots. They book. You get notified. No double-bookings.</p>
      </div>
    </div>
  </section>

  <!-- Social Proof / GitHub -->
  <section style="padding: 2rem 1.5rem 5rem; max-width: 600px; margin: 0 auto; text-align: center;">
    <div style="padding: 2rem; border-radius: 1rem; border: 1px solid var(--app-border); background: rgba(255,255,255,0.02);">
      <div style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--app-text-muted); margin-bottom: 0.75rem;">Open Source</div>
      <p style="font-size: 0.95rem; color: var(--app-text-muted); margin: 0 0 1.25rem; line-height: 1.6;">
        Built with PostgreSQL, PostgREST, and Astro. No Redis. No Elasticsearch. No vendor lock-in.
      </p>
      <a href="https://github.com/SASS-Killers/OpenSchedule" target="_blank" class="app-btn" style="padding: 0.75rem 1.5rem; gap: 0.5rem; display: inline-flex; align-items: center;">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        View on GitHub
      </a>
      <div style="margin-top: 1rem; display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; font-size: 0.8rem; color: var(--app-text-muted);">
        <span>Neon PostgreSQL</span>
        <span>·</span>
        <span>PostgREST</span>
        <span>·</span>
        <span>Astro</span>
        <span>·</span>
        <span>Cloudflare Pages</span>
        <span>·</span>
        <span>React</span>
      </div>
    </div>
  </section>
</AppLayout>
