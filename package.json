{
  "name": "open-calendar",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts,.tsx --max-warnings 50",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro}\"",
    "audit": "npm run lint && npm run format:check && npm run test:coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,astro}": [
      "prettier --write",
      "eslint --fix --max-warnings 200"
    ]
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.2",
    "@astrojs/react": "^5.0.5",
    "@cloudflare/workers-types": "^4.20260519.1",
    "@neondatabase/serverless": "^1.1.0",
    "astro": "^6.3.5",
    "jose": "^6.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "9.24.0",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "vitest": "^4.1.7",
    "wrangler": "^4.93.0"
  }
}
